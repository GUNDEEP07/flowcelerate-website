---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    icon: '⚙️',
    title: 'ITSM Transformation',
    description: 'Incident, problem, change, and request management redesigned around your regulatory obligations and service tiers — not generic ITIL theory.',
    href: '/services/itsm',
    tags: ['Incident Management', 'Change Advisory', 'ITIL 4', 'SLA Design', 'Problem Management'],
  },
  {
    icon: '🖥️',
    title: 'SAM Pro',
    description: 'Software asset management that survives an audit. Entitlement reconciliation, publisher compliance, and renewal forecasting for complex enterprise estates.',
    href: '/services/sam-pro',
    tags: ['Entitlements', 'Discovery Integration', 'Publisher Compliance', 'Renewal Forecasting'],
  },
  {
    icon: '🗂️',
    title: 'CMDB / CSDM',
    description: 'A CMDB architecture grounded in the Common Service Data Model — built for operational resilience reporting, not just asset inventory.',
    href: '/services/cmdb-csdm',
    tags: ['CSDM', 'Service Mapping', 'Discovery', 'DORA', 'Operational Resilience'],
  },
  {
    icon: '🤖',
    title: 'AI & Agentic Architecture',
    description: 'Flow Designer orchestration with Now Assist and GenAI actions — agentic workflows that hold up under financial services governance requirements.',
    href: '/services/ai-architecture',
    tags: ['Now Assist', 'Skill Builder', 'Flow Designer', 'GenAI', 'Human-in-the-Loop'],
  },
];
---

<Layout
  title="Services — Flowcelerate"
  description="ServiceNow consulting services for insurance and financial services: ITSM, SAM Pro, CMDB/CSDM, and AI architecture from a Certified Technical Architect."
>
  <section class="bg-navy-900 relative overflow-hidden" aria-labelledby="services-heading">
    <div class="absolute inset-0 grid-dots opacity-20 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-teal-light uppercase tracking-wider mb-4">Services</p>
        <h1 id="services-heading" class="font-display font-800 text-4xl sm:text-5xl text-white text-balance">
          Four focused practice areas. One platform.
        </h1>
        <p class="mt-6 text-slate-300 text-lg leading-relaxed">
          Each service is designed around the specific business problems insurance and financial services enterprises face on ServiceNow — not adapted from a generic enterprise playbook.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50" aria-label="Service areas">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {services.map((s) => (
          <ServiceCard {...s} />
        ))}
      </div>
    </div>
  </section>

  <!-- Engagement Packages Section -->
  <section class="py-20 bg-white border-t border-slate-100" aria-labelledby="packages-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Structured Offerings</p>
        <h2 id="packages-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900 text-balance">
          Fixed-scope consulting packages
        </h2>
        <p class="mt-4 text-slate-600 text-lg">
          High-impact engagements designed to target your most critical ServiceNow challenges without the complexity or variable cost of traditional contracts.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          {
            title: 'DORA CMDB Readiness Review',
            scope: '10-Day Fixed Assessment',
            pricing: 'Fixed Price',
            badge: 'Urgent Compliance',
            badgeColor: 'bg-red-50 text-red-700 border-red-100',
            desc: 'Evaluate your CMDB & CSDM mapping maturity against DORA Chapter V obligations. Identify gaps in technical CI mapping for your critical business applications.',
            deliverables: ['Detailed regulatory gap report', 'CSDM Service Mapping blueprint', 'Operational resilience dashboard mockups'],
            href: '/contact',
            actionText: 'Inquire Package',
          },
          {
            title: 'SAM Pro License Audit Defense',
            scope: 'Targeted Risk Review',
            pricing: 'Fixed Price',
            badge: 'Cost Protection',
            badgeColor: 'bg-teal-50 text-teal-700 border-teal-100',
            desc: 'Entitlement reconciliation and deployment audit prep for high-exposure publishers (Oracle, Microsoft, IBM). Identify licensing waste and true-up risks.',
            deliverables: ['Effective License Position (ELP) scorecard', 'Licensing waste reclamation plan', 'Publisher audit response playbook'],
            href: '/contact',
            actionText: 'Inquire Package',
          },
          {
            title: 'ServiceNow AI & Agentic Strategy',
            scope: 'Architectural Blueprint',
            pricing: 'Fixed Price',
            badge: 'Innovation Governance',
            badgeColor: 'bg-blue-50 text-blue-700 border-blue-100',
            desc: 'Design Now Assist and Flow Designer GenAI architectures with built-in model risk boundaries. Ensure your automated flows clear internal compliance gates.',
            deliverables: ['GenAI flow design blueprint', 'Model risk assessment templates', 'Confidence-routing governance flowcharts'],
            href: '/contact',
            actionText: 'Inquire Package',
          },
          {
            title: 'Fractional CTA Peer Review Retainer',
            scope: 'Fractional Advisory',
            pricing: 'Monthly Retainer',
            badge: 'Ongoing Oversight',
            badgeColor: 'bg-indigo-50 text-indigo-700 border-indigo-100',
            desc: 'Independent architectural oversight of your platform roadmap. We review technical designs and code delivered by your implementation partner to prevent technical debt.',
            deliverables: ['Bi-weekly design review calls', 'Independent build quality audits', 'Strategic roadmap alignment reviews'],
            href: '/contact',
            actionText: 'Inquire Retainer',
          },
          {
            title: '1-Hour Architecture Review',
            scope: 'Live 1-on-1 Session',
            pricing: '£250 (Credited Back)',
            badge: 'On-Demand Advisory',
            badgeColor: 'bg-emerald-50 text-emerald-700 border-emerald-100',
            desc: 'A focused, live session to troubleshoot a specific CMDB discovery block, review a vendor design proposal, or audit a custom integration blueprint.',
            deliverables: ['Live screenshare troubleshooting', 'Written architecture feedback report', 'Full credit toward any audit or retainer signed'],
            href: '/book',
            actionText: 'Book Review',
          },
          {
            title: 'Slack-a-CTA Support Retainer',
            scope: 'Micro-Advisory Retainer',
            pricing: '£950 / Month',
            badge: 'On-Demand Support',
            badgeColor: 'bg-amber-50 text-amber-700 border-amber-100',
            desc: 'Direct, unlimited Slack/Teams access to a Certified Technical Architect (CTA) for your internal ServiceNow admin and development team.',
            deliverables: ['Guaranteed <24h response time', 'Unlimited architecture & CSDM Q&A', 'Neutral code reviews without meeting overhead'],
            href: '/contact',
            actionText: 'Subscribe Retainer',
          },
        ].map((pkg) => (
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 sm:p-8 hover:border-accent/30 hover:shadow-lg transition-all duration-200 flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between gap-4 mb-4">
                <span class={`px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider border rounded-md ${pkg.badgeColor}`}>
                  {pkg.badge}
                </span>
                <span class="text-xs font-mono font-semibold text-slate-400 uppercase">{pkg.scope}</span>
              </div>
              <h3 class="font-display font-800 text-navy-900 text-xl sm:text-2xl mb-3">{pkg.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed mb-6 font-sans">{pkg.desc}</p>
              
              <div class="border-t border-slate-200/60 pt-5 mb-6">
                <p class="text-xs font-bold text-navy-900 uppercase tracking-wider mb-3">Key Deliverables:</p>
                <ul class="space-y-2">
                  {pkg.deliverables.map((item) => (
                    <li class="flex items-start gap-2.5 text-xs sm:text-sm text-slate-600 font-sans">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="mt-0.5 shrink-0" aria-hidden="true">
                        <path d="M2 7L5.5 10.5L12 3.5" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            
            <div class="border-t border-slate-200/60 pt-5 flex items-center justify-between gap-4">
              <span class="text-sm font-bold text-navy-900 uppercase tracking-wider font-mono">{pkg.pricing}</span>
              <a
                href={pkg.href}
                class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors shadow-md shadow-blue-500/10"
              >
                {pkg.actionText}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How engagements work -->
  <section class="py-20 bg-white" aria-labelledby="engagement-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Engagement model</p>
        <h2 id="engagement-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900 text-balance">
          How a Flowcelerate engagement works
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          {
            step: '01',
            title: 'Discovery',
            body: 'A structured assessment of your current platform state, pain points, and objectives. Delivered as a written report with prioritised findings.',
          },
          {
            step: '02',
            title: 'Architecture Design',
            body: 'A documented design covering data model, process flows, integrations, and governance. Reviewed and agreed before build begins.',
          },
          {
            step: '03',
            title: 'Build & Validate',
            body: 'Implementation against the agreed design, with test scripts and review checkpoints at each milestone.',
          },
          {
            step: '04',
            title: 'Handover',
            body: 'Knowledge transfer, operational documentation, and a structured transition to your internal team or nominated support partner.',
          },
        ].map((phase) => (
          <div class="relative p-6 bg-slate-50 rounded-xl border border-slate-200">
            <span class="font-display font-800 text-5xl text-slate-200 absolute top-4 right-5" aria-hidden="true">
              {phase.step}
            </span>
            <h3 class="font-display font-700 text-lg text-navy-900 mb-2 relative">{phase.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed relative">{phase.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
