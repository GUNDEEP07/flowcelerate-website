---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const services = [
  {
    icon: '⚙️',
    title: 'ITSM Transformation',
    description: 'Incident, problem, change, and request management redesigned around your regulatory obligations and service tiers — not generic ITIL theory.',
    href: '/services/itsm',
    tags: ['Incident', 'Change', 'ITIL 4', 'SLA Design'],
  },
  {
    icon: '🖥️',
    title: 'SAM Pro',
    description: 'Software asset management that survives an audit. Entitlement reconciliation, publisher compliance, and renewal forecasting for complex enterprise estates.',
    href: '/services/sam-pro',
    tags: ['Entitlements', 'Compliance', 'Publisher Risk'],
  },
  {
    icon: '🗂️',
    title: 'CMDB / CSDM',
    description: 'A CMDB architecture grounded in the Common Service Data Model — built for operational resilience reporting, not just asset inventory.',
    href: '/services/cmdb-csdm',
    tags: ['CSDM', 'Discovery', 'Service Mapping', 'DORA'],
  },
  {
    icon: '🤖',
    title: 'AI & Agentic Architecture',
    description: 'Flow Designer orchestration with Now Assist and GenAI actions — agentic workflows that hold up under financial services governance requirements.',
    href: '/services/ai-architecture',
    tags: ['Now Assist', 'Flow Designer', 'GenAI', 'Automation'],
  },
];

const credentials = [
  { label: 'ServiceNow Certified Technical Architect (CTA)' },
  { label: 'CIS — ITSM' },
  { label: 'CIS — HRSD' },
  { label: '10+ years ServiceNow' },
  { label: 'Insurance · Reinsurance · Financial Services' },
];
---

<Layout
  title="Flowcelerate — ServiceNow Architecture for Insurance & Financial Services"
  description="Independent ServiceNow CTA specialising in ITSM, SAM Pro, CMDB/CSDM, and AI architecture for insurance, reinsurance, and financial services enterprises."
>
  <!-- Hero -->
  <Hero
    badge="ServiceNow Certified Technical Architect"
    headline="ServiceNow Architecture Built for Insurance & Financial Services"
    subheadline="Independent consulting from a CTA with 10+ years designing platforms that meet the complexity of insurance operations, reinsurance treaties, and regulated financial services."
    ctaPrimary={{ href: '/book', label: 'Book a Discovery Call' }}
    ctaSecondary={{ href: '/services', label: 'View Services' }}
    variant="dark"
  />

  <!-- Credentials strip -->
  <section class="bg-navy-800 border-y border-white/10" aria-label="Credentials">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {credentials.map((c) => (
          <div class="flex items-center gap-2 text-slate-300 text-sm">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7L5.5 10.5L12 3.5" stroke="#14b8a6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{c.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-20 bg-slate-50" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Services</p>
        <h2 id="services-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900 text-balance">
          Precision ServiceNow practice across the full platform
        </h2>
        <p class="mt-4 text-slate-600 text-lg">
          Engagements are designed around outcomes — not billable hours. Each practice area addresses the specific problems insurance and financial services firms face on the ServiceNow platform.
        </p>
      </div>

      <!-- Bento Grid Services -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- ITSM Transformation -->
        <a
          href="/services/itsm"
          class="group block p-6 bg-white border border-slate-200 rounded-2xl hover:border-accent/40 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-200"
          aria-label="Learn more about ITSM Transformation"
        >
          <div class="w-11 h-11 bg-accent-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent group-hover:text-white transition-colors duration-200">
            <span class="text-accent group-hover:text-white text-xl transition-colors duration-200" aria-hidden="true">⚙️</span>
          </div>
          <h3 class="font-display font-700 text-navy-900 text-lg mb-2 group-hover:text-accent transition-colors duration-200">
            ITSM Transformation
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4 font-sans">
            Incident, problem, change, and request management redesigned around your regulatory obligations (FCA, PRA) and service tiers — not generic ITIL theory.
          </p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {['Incident', 'Change', 'ITIL 4', 'SLA Design'].map((tag) => (
              <span class="px-2 py-0.5 text-xs font-semibold text-slate-500 bg-slate-100 rounded-full">{tag}</span>
            ))}
          </div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent group-hover:gap-2 transition-all duration-150">
            Learn more
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <!-- SAM Pro -->
        <a
          href="/services/sam-pro"
          class="group block p-6 bg-white border border-slate-200 rounded-2xl hover:border-accent/40 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-200"
          aria-label="Learn more about SAM Pro"
        >
          <div class="w-11 h-11 bg-accent-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent group-hover:text-white transition-colors duration-200">
            <span class="text-accent group-hover:text-white text-xl transition-colors duration-200" aria-hidden="true">🖥️</span>
          </div>
          <h3 class="font-display font-700 text-navy-900 text-lg mb-2 group-hover:text-accent transition-colors duration-200">
            SAM Pro
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4 font-sans">
            Software asset management that survives an audit. Entitlement reconciliation, publisher compliance (Oracle, Microsoft, IBM), and cost optimization.
          </p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {['Entitlements', 'Compliance', 'Publisher Risk'].map((tag) => (
              <span class="px-2 py-0.5 text-xs font-semibold text-slate-500 bg-slate-100 rounded-full">{tag}</span>
            ))}
          </div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent group-hover:gap-2 transition-all duration-150">
            Learn more
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <!-- CMDB / CSDM (Double Width Featured Block) -->
        <a
          href="/services/cmdb-csdm"
          class="group block p-6 bg-gradient-to-br from-accent/5 to-transparent border border-accent/20 rounded-2xl hover:border-accent/50 hover:shadow-xl hover:shadow-blue-500/8 transition-all duration-200 lg:col-span-1"
          aria-label="Learn more about CMDB / CSDM"
        >
          <div class="w-11 h-11 bg-accent rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent-dark transition-colors duration-200 shadow-md">
            <span class="text-white text-xl" aria-hidden="true">🗂️</span>
          </div>
          <h3 class="font-display font-700 text-navy-900 text-lg mb-2 group-hover:text-accent transition-colors duration-200">
            CMDB / CSDM
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4 font-sans">
            A CMDB architecture grounded in the Common Service Data Model — built for operational resilience reporting (DORA, Solvency II), not just simple asset inventory.
          </p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {['CSDM', 'Discovery', 'Service Mapping', 'DORA'].map((tag) => (
              <span class="px-2 py-0.5 text-xs font-semibold text-accent bg-accent-50 rounded-full border border-accent-100">{tag}</span>
            ))}
          </div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-accent group-hover:gap-2 transition-all duration-150">
            Design dynamic service map
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <!-- AI & Agentic Architecture (Full Width Premium Dark Card) -->
        <a
          href="/services/ai-architecture"
          class="group block p-6 sm:p-8 bg-navy-950 border border-white/10 rounded-2xl hover:border-accent/60 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-200 lg:col-span-3 relative overflow-hidden"
          aria-label="Learn more about AI & Agentic Architecture"
        >
          <!-- Background accent glow -->
          <div class="absolute -right-16 -top-16 w-48 h-48 rounded-full bg-accent/20 blur-3xl pointer-events-none group-hover:bg-accent/30 transition-all" aria-hidden="true"></div>
          
          <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div class="max-w-xl">
              <div class="w-11 h-11 bg-accent/20 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent group-hover:text-white transition-colors duration-200 border border-accent/30">
                <span class="text-accent-light group-hover:text-white text-xl transition-colors duration-200" aria-hidden="true">🤖</span>
              </div>
              <h3 class="font-display font-800 text-white text-xl sm:text-2xl mb-2 group-hover:text-accent-light transition-colors duration-200">
                AI & Agentic Architecture
              </h3>
              <p class="text-slate-300 text-sm leading-relaxed mb-4 font-sans">
                Flow Designer orchestration with Now Assist and GenAI actions. Build audit-proof agentic workflows that securely pass financial services model risk reviews.
              </p>
              <div class="flex flex-wrap gap-1.5">
                {['Now Assist', 'Flow Designer', 'GenAI', 'Automation'].map((tag) => (
                  <span class="px-2.5 py-0.5 text-xs font-semibold text-slate-300 bg-white/5 rounded-full border border-white/10">{tag}</span>
                ))}
              </div>
            </div>
            
            <div class="shrink-0 flex items-center gap-2 text-sm font-semibold text-accent-light group-hover:text-white transition-colors">
              Deploy secure agentic flows
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="group-hover:translate-x-1 transition-transform">
                <path d="M3 8H13M8 3L13 8L8 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      </div>

      <div class="mt-8 text-center">
        <a
          href="/services"
          class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-dark transition-colors"
        >
          View all services
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why section -->
  <section class="py-20 bg-white" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Why Flowcelerate</p>
          <h2 id="why-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900 text-balance">
            The depth of a specialist. The perspective of an architect.
          </h2>
          <p class="mt-5 text-slate-600 leading-relaxed">
            Most ServiceNow partners sell delivery capacity. What insurance and financial services firms need is architectural judgement — someone who understands both the platform and the regulatory context deeply enough to design solutions that hold up over time.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            As a sole practitioner, you work directly with the person who designed the solution. No account managers, no junior handoffs. The CTA you spoke with in scoping is the one writing the design document and reviewing the build.
          </p>
          <a
            href="/about"
            class="inline-flex items-center gap-2 mt-6 text-sm font-medium text-accent hover:text-accent-dark transition-colors"
          >
            About this practice
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { number: '10+', label: 'Years on ServiceNow', sub: 'Since Fuji / Geneva' },
            { number: 'CTA', label: 'Certified Technical Architect', sub: "ServiceNow's highest cert" },
            { number: '100%', label: 'Insurance & FS focus', sub: 'No generalist engagements' },
            { number: 'Solo', label: 'Practitioner model', sub: 'No junior handoffs' },
          ].map((stat) => (
            <div class="p-5 bg-slate-50 rounded-xl border border-slate-200">
              <p class="font-display font-800 text-3xl text-navy-900">{stat.number}</p>
              <p class="font-medium text-navy-900 text-sm mt-1">{stat.label}</p>
              <p class="text-slate-500 text-xs mt-0.5">{stat.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes teasers -->
  <section class="py-20 bg-slate-50" aria-labelledby="proof-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Outcomes</p>
        <h2 id="proof-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900">
          Results from the field
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            industry: 'Global Reinsurer',
            outcome: '60% reduction in CMDB data quality incidents',
            context: 'CSDM implementation anchored on treaty processing and catastrophe modelling services',
          },
          {
            industry: "Lloyd's Managing Agent",
            outcome: '£2.1M in identified software cost avoidance',
            context: 'SAM Pro deployment covering Oracle, Microsoft, and 40+ niche financial applications',
          },
          {
            industry: 'Tier-1 P&C Carrier',
            outcome: 'DORA operational resilience report automated from live CMDB data',
            context: 'CSDM + Service Mapping + Flow Designer integration replacing quarterly manual exercise',
          },
        ].map((cs) => (
          <div class="p-6 bg-white border border-slate-200 rounded-xl">
            <span class="inline-block px-2.5 py-1 text-xs font-medium text-teal bg-teal/10 rounded-full mb-4">
              {cs.industry}
            </span>
            <p class="font-display font-700 text-navy-900 text-lg leading-snug mb-2">{cs.outcome}</p>
            <p class="text-slate-500 text-sm leading-relaxed">{cs.context}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-dark transition-colors"
        >
          Read full case studies
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent insights -->
  {posts.length > 0 && (
    <section class="py-20 bg-white" aria-labelledby="insights-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Insights</p>
            <h2 id="insights-heading" class="font-display font-800 text-3xl text-navy-900">Latest thinking</h2>
          </div>
          <a
            href="/insights"
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-accent-dark transition-colors"
          >
            All posts
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
              readingTime={post.data.readingTime}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTASection />
</Layout>
