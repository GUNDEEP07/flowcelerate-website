---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import TrackCard from '../../components/TrackCard.astro';
import PlaybookCard from '../../components/PlaybookCard.astro';
import WorkshopCard from '../../components/WorkshopCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';

const allPlaybooks = (await getCollection('playbooks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allWorkshops = (await getCollection('workshops', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.nextDate?.valueOf() ?? 0) - (b.data.nextDate?.valueOf() ?? 0));

const practitionerPlaybooks = allPlaybooks.filter(p => p.data.track === 'practitioner');
const leadershipPlaybooks   = allPlaybooks.filter(p => p.data.track === 'leadership');
const practitionerWorkshops = allWorkshops.filter(w => w.data.track === 'practitioner');
const leadershipWorkshops   = allWorkshops.filter(w => w.data.track === 'leadership');

const featuredPlaybooks = allPlaybooks.slice(0, 3);
const upcomingWorkshops = allWorkshops.filter(w => w.data.openEnrollment).slice(0, 2);
---

<Layout
  title="Training — Flowcelerate"
  description="ServiceNow training for insurance and financial services practitioners and IT leaders. Playbooks, workshops, and courses built for regulated environments."
>
  <Hero
    badge="Training & Education"
    headline="ServiceNow training built for insurance and financial services"
    subheadline="Playbooks, workshops, and courses designed for the platform challenges and regulatory context of insurance carriers, reinsurers, and FS firms."
    ctaPrimary={{ href: '/training/playbooks', label: 'Browse Playbooks' }}
    ctaSecondary={{ href: '/training/workshops', label: 'View Workshops' }}
    variant="dark"
  />

  <!-- Tracks -->
  <section class="py-20 bg-slate-50" aria-labelledby="tracks-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-10">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Two tracks</p>
        <h2 id="tracks-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900 text-balance">
          Find the content built for your role
        </h2>
      </div>
      <!-- Track Comparison Table Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-10">
        <!-- Practitioner Track Card -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 hover:border-accent/30 hover:shadow-lg transition-all duration-200 flex flex-col justify-between">
          <div>
            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-accent-50 rounded-full mb-5">
              <span class="w-1.5 h-1.5 bg-accent rounded-full" aria-hidden="true"></span>
              <span class="text-xs font-bold text-accent uppercase tracking-wider">Practitioner Track</span>
            </div>
            <h3 class="font-display font-800 text-navy-900 text-2xl mb-4">Hands-On Platform Engineers</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 font-sans">
              Deep-dive technical instruction for ServiceNow administrators, developers, and architects who write the code, configure CSDM, and implement Flow Designer.
            </p>
            <ul class="space-y-3 mb-8 border-t border-slate-100 pt-6">
              {[
                { label: 'Target Roles', val: 'Architects, Developers, CMDB Leads' },
                { label: 'Core Focus', val: 'CSDM classes, S3/SES APIs, Flow rules' },
                { label: 'Practical Takeaway', val: 'Ready-to-deploy update sets & XML blueprints' }
              ].map(item => (
                <li class="flex flex-col sm:flex-row sm:justify-between text-xs sm:text-sm font-sans">
                  <span class="text-slate-400 font-semibold">{item.label}</span>
                  <span class="text-navy-900 font-bold sm:text-right mt-0.5 sm:mt-0">{item.val}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex items-center justify-between border-t border-slate-100 pt-6">
            <span class="text-xs text-slate-400 font-sans font-semibold">
              {practitionerPlaybooks.length} playbooks · {practitionerWorkshops.length} workshops
            </span>
            <a
              href="/training/practitioners"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors shadow-md shadow-blue-500/10"
            >
              Explore Track
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Leadership Track Card -->
        <div class="bg-navy-950 border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-accent/40 hover:shadow-lg transition-all duration-200 flex flex-col justify-between text-white relative overflow-hidden">
          <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-accent/20 blur-2xl pointer-events-none" aria-hidden="true"></div>
          <div>
            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/5 rounded-full mb-5 border border-white/10 relative z-10">
              <span class="w-1.5 h-1.5 bg-teal-light rounded-full" aria-hidden="true"></span>
              <span class="text-xs font-bold text-slate-300 uppercase tracking-wider">Leadership Track</span>
            </div>
            <h3 class="font-display font-800 text-white text-2xl mb-4 relative z-10">Strategic & IT Decision Makers</h3>
            <p class="text-slate-300 text-sm leading-relaxed mb-6 font-sans relative z-10">
              Governance and architectural blueprints for CIOs, risk directors, and heads of IT. Understand what good CMDB looks like and how to clear internal audit boundaries.
            </p>
            <ul class="space-y-3 mb-8 border-t border-white/5 pt-6 relative z-10">
              {[
                { label: 'Target Roles', val: 'CIOs, IT Directors, CROs, Risk Managers' },
                { label: 'Core Focus', val: 'DORA compliance, audit defense, ORSA reporting' },
                { label: 'Practical Takeaway', val: 'Platform governance templates & risk matrix' }
              ].map(item => (
                <li class="flex flex-col sm:flex-row sm:justify-between text-xs sm:text-sm font-sans">
                  <span class="text-slate-400 font-semibold">{item.label}</span>
                  <span class="text-white font-bold sm:text-right mt-0.5 sm:mt-0">{item.val}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex items-center justify-between border-t border-white/5 pt-6 relative z-10">
            <span class="text-xs text-slate-400 font-sans font-semibold">
              {leadershipPlaybooks.length} playbooks · {leadershipWorkshops.length} workshops
            </span>
            <a
              href="/training/leaders"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold text-navy-950 bg-white hover:bg-slate-100 rounded-lg transition-colors"
            >
              Explore Track
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured playbooks -->
  {featuredPlaybooks.length > 0 && (
    <section class="py-20 bg-white" aria-labelledby="playbooks-feat-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Playbooks</p>
            <h2 id="playbooks-feat-heading" class="font-display font-800 text-3xl text-navy-900">Free PDF guides</h2>
          </div>
          <a href="/training/playbooks" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
            All playbooks
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {featuredPlaybooks.map(p => (
            <PlaybookCard
              title={p.data.title}
              description={p.data.description}
              track={p.data.track}
              topics={p.data.topics}
              pages={p.data.pages}
              href={`/training/playbooks/${p.id}`}
              gated={p.data.gated}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Digital Toolkits Store Catalog -->
  <section class="py-20 bg-slate-50 border-t border-b border-slate-200/60" aria-labelledby="toolkits-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">Digital Products</p>
        <h2 id="toolkits-heading" class="font-display font-800 text-3xl sm:text-4xl text-navy-900">
          Compliance & Licensing Toolkits
        </h2>
        <p class="mt-4 text-slate-600 text-lg font-sans">
          Downloadable configurations, Excel matrices, and standard operating blueprints to kickstart your implementations without full-scale advisory fees.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- DORA CMDB Toolkit -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 hover:shadow-lg transition-all flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between gap-4 mb-4">
              <span class="px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-red-700 bg-red-50 border border-red-100 rounded-md">Update Sets & Assets</span>
              <span class="text-xs font-mono font-semibold text-slate-400">INSTANT ACCESS</span>
            </div>
            <h3 class="font-display font-800 text-navy-900 text-xl sm:text-2xl mb-3">DORA CMDB Compliance Toolkit</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 font-sans">
              Jumpstart your Operational Resilience reporting. Contains ready-to-import XML Update Sets for configuration dashboard health, template spreadsheets for mapping CI ownership, and model walkthrough videos.
            </p>
            <ul class="space-y-2.5 mb-8 border-t border-slate-100 pt-6">
              {[
                'ServiceNow Update Set XML (Health Prefs)',
                'Important Business Services (IBS) mapping matrix',
                'Operational Resilience dashboard schema guides',
              ].map(item => (
                <li class="flex items-start gap-2.5 text-xs sm:text-sm text-slate-600 font-sans">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="mt-0.5 shrink-0" aria-hidden="true">
                    <path d="M2 7L5.5 10.5L12 3.5" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="border-t border-slate-100 pt-5 flex items-center justify-between gap-4">
            <span class="text-lg font-bold text-navy-900 font-mono">£199</span>
            <a
              href="/contact?subject=Purchase%20DORA%20CMDB%20Toolkit"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors shadow-md shadow-blue-500/10"
            >
              Get Toolkit
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- SAM Pro Toolkit -->
        <div class="bg-white border border-slate-200 rounded-2xl p-6 sm:p-8 hover:shadow-lg transition-all flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between gap-4 mb-4">
              <span class="px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-teal-700 bg-teal-50 border border-teal-100 rounded-md">Blueprints & Playbooks</span>
              <span class="text-xs font-mono font-semibold text-slate-400">INSTANT ACCESS</span>
            </div>
            <h3 class="font-display font-800 text-navy-900 text-xl sm:text-2xl mb-3">SAM Pro Publisher Defensibility Toolkit</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6 font-sans">
              Defend your virtualized software clusters against aggressive publisher audits. Contains Oracle processor-core calculation sheets, Azure Hybrid benefit templates, and publisher audit response playbook SOPs.
            </p>
            <ul class="space-y-2.5 mb-8 border-t border-slate-100 pt-6">
              {[
                'Oracle core metrics & processor calculation sheet',
                'Microsoft EA & Azure hybrid reconciliation workbook',
                'Audit response Standard Operating Procedures (SOPs)',
              ].map(item => (
                <li class="flex items-start gap-2.5 text-xs sm:text-sm text-slate-600 font-sans">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="mt-0.5 shrink-0" aria-hidden="true">
                    <path d="M2 7L5.5 10.5L12 3.5" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="border-t border-slate-100 pt-5 flex items-center justify-between gap-4">
            <span class="text-lg font-bold text-navy-900 font-mono">£249</span>
            <a
              href="/contact?subject=Purchase%20SAM%20Pro%20Defensibility%20Toolkit"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold text-white bg-accent hover:bg-accent-dark rounded-lg transition-colors shadow-md shadow-blue-500/10"
            >
              Get Toolkit
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 6H10M6 2L10 6L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming workshops -->
  {upcomingWorkshops.length > 0 && (
    <section class="py-20 bg-slate-50" aria-labelledby="workshops-feat-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Workshops</p>
            <h2 id="workshops-feat-heading" class="font-display font-800 text-3xl text-navy-900">Upcoming live sessions</h2>
          </div>
          <a href="/training/workshops" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-accent-dark transition-colors">
            All workshops
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {upcomingWorkshops.map(w => (
            <WorkshopCard
              title={w.data.title}
              description={w.data.description}
              track={w.data.track}
              format={w.data.format}
              duration={w.data.duration}
              price={w.data.price}
              maxParticipants={w.data.maxParticipants}
              nextDate={w.data.nextDate}
              openEnrollment={w.data.openEnrollment}
              href={`/training/workshops/${w.id}`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="py-20 bg-white" aria-labelledby="nl-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-3 text-center">Community</p>
      <h2 id="nl-heading" class="font-display font-800 text-3xl text-navy-900 text-center mb-8 text-balance">
        Monthly insights, straight to your inbox
      </h2>
      <NewsletterSignup />
    </div>
  </section>

  <CTASection
    headline="Need something bespoke?"
    body="The training catalogue covers the most common challenges. If you need a workshop designed around your specific platform and regulatory context, let's talk."
    ctaLabel="Book a Discovery Call"
    secondaryLabel="View Services"
    secondaryHref="/services"
  />
</Layout>
