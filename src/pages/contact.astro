---
import Layout from '../layouts/Layout.astro';
import CalendlyInline from '../components/CalendlyInline.astro';
---

<Layout
  title="Contact — Flowcelerate"
  description="Get in touch with Flowcelerate to discuss your ServiceNow architecture needs. Book a discovery call or send a message."
>
  <section class="bg-navy-900 relative overflow-hidden" aria-labelledby="contact-heading">
    <div class="absolute inset-0 grid-dots opacity-20 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-teal-light uppercase tracking-wider mb-4">Contact</p>
        <h1 id="contact-heading" class="font-display font-800 text-4xl sm:text-5xl text-white text-balance">
          Let's discuss your ServiceNow platform
        </h1>
        <p class="mt-6 text-slate-300 text-lg leading-relaxed">
          Whether you have a specific problem to solve or want to understand whether your platform architecture is heading in the right direction, a focused 30-minute call is the best starting point.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white" aria-label="Contact options">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Contact form -->
        <div>
          <h2 class="font-display font-700 text-2xl text-navy-900 mb-2">Send a message</h2>
          <p class="text-slate-500 text-sm mb-8">Prefer async? Use the form below. I respond to all enquiries within one business day.</p>

          <form
            name="contact"
            method="POST"
            action="/contact/success"
            class="space-y-5"
            aria-label="Contact form"
            novalidate
          >
            <div>
              <label for="name" class="block text-sm font-medium text-navy-900 mb-1.5">
                Full name <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-3.5 py-2.5 rounded-lg border border-slate-200 text-slate-800 placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
                placeholder="Jane Smith"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-navy-900 mb-1.5">
                Work email <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="work email"
                class="w-full px-3.5 py-2.5 rounded-lg border border-slate-200 text-slate-800 placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
                placeholder="jane@company.com"
              />
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-navy-900 mb-1.5">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                autocomplete="organization"
                class="w-full px-3.5 py-2.5 rounded-lg border border-slate-200 text-slate-800 placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
                placeholder="Acme Re"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-navy-900 mb-1.5">
                Message <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                class="w-full px-3.5 py-2.5 rounded-lg border border-slate-200 text-slate-800 placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors resize-y"
                placeholder="Briefly describe what you're working on or the problem you're trying to solve..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold text-white bg-accent hover:bg-accent-dark transition-colors duration-150"
            >
              Send message
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 7H11M7 3L11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>

          <!-- LinkedIn -->
          <div class="mt-10 pt-8 border-t border-slate-100">
            <p class="text-sm text-slate-500 mb-3">Connect on LinkedIn</p>
            <a
              href="https://linkedin.com/in/YOUR-PROFILE"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 px-4 py-2.5 bg-[#0A66C2] text-white text-sm font-medium rounded-lg hover:bg-[#004182] transition-colors"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn profile
            </a>
          </div>
        </div>

        <!-- Calendly inline embed -->
        <div>
          <h2 class="font-display font-700 text-2xl text-navy-900 mb-2">Book a consultation</h2>
          <p class="text-slate-500 text-sm mb-8">
            Choose a time that works. 30-minute discovery call, no obligation.
          </p>
          <CalendlyInline minHeight="600px" />
        </div>
      </div>
    </div>
  </section>
</Layout>
